# ==========================================
# Medical Coverage System - Docker Environment Configuration
# ==========================================
# Environment variables for docker-compose
# For Docker: Services communicate via container names (postgres, redis)

# --- Node Environment ---
NODE_ENV=development

# --- Database Configuration ---
DB_USER=postgres
DB_PASSWORD=postgres_password_2024
DB_PORT=5432
DB_HOST=postgres

# --- Redis Configuration ---
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# --- Frontend Configuration ---
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_ENVIRONMENT=development

# --- API Gateway ---
GATEWAY_PORT=3001

# --- Authentication & Security ---
JWT_SECRET=change_me_in_production_min_32_chars_long_secure
JWT_REFRESH_SECRET=change_me_refresh_secret_production_secure
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# --- Service Ports ---
BILLING_PORT=3002
CORE_PORT=3003
FINANCE_PORT=3004
CRM_PORT=3005
MEMBERSHIP_PORT=3006
HOSPITAL_PORT=3007
INSURANCE_PORT=3008
WELLNESS_PORT=3009

# --- Service URLs (inter-service communication) ---
CORE_SERVICE_URL=http://core-service:3003
INSURANCE_SERVICE_URL=http://insurance-service:3008
HOSPITAL_SERVICE_URL=http://hospital-service:3007
BILLING_SERVICE_URL=http://billing-service:3002
FINANCE_SERVICE_URL=http://finance-service:3004
CRM_SERVICE_URL=http://crm-service:3005
MEMBERSHIP_SERVICE_URL=http://membership-service:3006
WELLNESS_SERVICE_URL=http://wellness-service:3009

# --- Email Configuration (Optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# --- File Storage ---
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# --- Logging ---
LOG_LEVEL=debug
LOG_FORMAT=json

# --- Feature Flags ---
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
SERVICE_TIMEOUT=30000
FILE_STORAGE_TYPE=local

# --- AWS S3 Configuration (Optional - for production file storage) ---
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-s3-bucket-name
# AWS_S3_ENDPOINT=https://s3.amazonaws.com

# --- Redis Configuration (Optional - for caching and sessions) ---
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0

# --- Background Jobs Configuration ---
# ENABLE_BACKGROUND_JOBS=true
# JOB_QUEUE_REDIS_URL=redis://localhost:6379/1
# JOB_CONCURRENCY=5
# FAILED_JOB_TTL=86400000

# --- Monitoring and Logging ---
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_FORMAT=combined

# --- Monitoring Services (Optional) ---
# SENTRY_DSN=your-sentry-dsn
# NEW_RELIC_LICENSE_KEY=your-newrelic-key
# DATADOG_API_KEY=your-datadog-key

# --- SSL Configuration (for HTTPS in production) ---
# SSL_CERT_PATH=/path/to/ssl/cert.pem
# SSL_KEY_PATH=/path/to/ssl/key.pem
# FORCE_HTTPS=false

# --- Backup Configuration ---
DB_BACKUP_PASSWORD=secure-backup-password
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# --- Feature Flags ---
ENABLE_MEMBER_ONBOARDING=true
ENABLE_ADMIN_DASHBOARD=true
ENABLE_AI_RECOMMENDATIONS=false
ENABLE_WELLNESS_PROGRAMS=true
ENABLE_DOCUMENT_UPLOAD=true
ENABLE_EMAIL_NOTIFICATIONS=true

# --- Schemes & Benefits Module Configuration ---
ENABLE_SCHEMES_BENEFITS=true
ENABLE_ADVANCED_PREMIUM_CALCULATION=true
ENABLE_RULES_ENGINE=true
ENABLE_PROVIDER_NETWORKS=true
ENABLE_CORPORATE_SCHEMES=true
SCHEMES_CACHE_TTL=3600
BENEFIT_RULES_CACHE_TTL=1800
PREMIUM_CALCULATION_TIMEOUT=30000
CLAIMS_ADJUDICATION_TIMEOUT=60000

# --- Provider Network Configuration ---
PROVIDER_TIER_DISCOUNTS={"tier_1":0.15,"tier_2":0.10,"tier_3":0.05,"premium":0.25}
PROVIDER_QUALITY_WEIGHTS={"clinical_outcomes":0.4,"patient_satisfaction":0.3,"cost_efficiency":0.2,"accessibility":0.1}
PROVIDER_PERFORMANCE_THRESHOLD=0.75

# --- AI & Personalization Configuration ---
AI_MODEL_URL=https://api.openai.com/v1
AI_API_KEY=your-openai-api-key
AI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7
PERSONALIZATION_ENABLED=true

# --- Wellness & Gamification ---
WELLNESS_POINTS_PER_ACTION=10
WELLNESS_STREAK_BONUS_MULTIPLIER=1.5
WELLNESS_LEVEL_UP_THRESHOLD=100

# --- Email Service Configuration ---
EMAIL_SERVICE_ENABLED=true
EMAIL_BATCH_SIZE=50
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY=1000

# --- Document Management ---
DOCUMENT_VERIFICATION_ENABLED=true
DOCUMENT_EXPIRY_DAYS=365
DOCUMENT_AUTO_DELETE_ENABLED=false

# --- Development Specific ---
DEV_SEED_DATA=true
DEV_MOCK_EMAIL_SERVICE=true
DEV_ENABLE_CORS_DEBUG=true

# --- Production Overrides ---
# NODE_ENV=production
# PORT=3000
# LOG_LEVEL=warn
# FORCE_HTTPS=true
# ENABLE_BACKGROUND_JOBS=true
# BACKUP_ENABLED=true
# AI_RECOMMENDATIONS_ENABLED=true