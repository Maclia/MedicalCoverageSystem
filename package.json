{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "client",
    "services/*",
    "shared"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:client": "cd client && vite",
    "build": "turbo run build",
    "build:client": "turbo run build --filter=medical-coverage-client",
    "build:server": "turbo run build --filter=./server",
    "build:services": "turbo run build --filter=./services/*",
    "build:prod": "NODE_ENV=production turbo run build",
    "turbo": "turbo",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "check:client": "cd client && tsc --noEmit",
    "check:server": "tsc --noEmit --skipLibCheck server/**/*.ts",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "migrate:auto": "node scripts/run-migrations.js",
    "migrate:auto:shell": "bash scripts/run-migrations.sh",
    "migrate:auto:batch": "scripts\\run-migrations.bat",
    "test:jest": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:components": "jest client/src/components --testPathPattern=\\.(test|spec)\\.(ts|tsx)$",
    "test:server": "jest server --testPathPattern=\\.(test|spec)\\.(ts)$",
    "test:integration": "jest --testPathPatterns=integration --testTimeout=30000",
    "test:e2e": "cypress run",
    "audit:all": "npm audit --workspaces",
    "update:all": "npm update --workspaces",
    "test:e2e:open": "cypress open",
    "test:e2e:headed": "cypress run --headed",
    "test:e2e:chrome": "cypress run --browser chrome",
    "test:e2e:component": "cypress run --component",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "docker:start": "./scripts/production/docker-start.sh"
  },
  "dependencies": {
    "@faker-js/faker": "^9.6.0",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@neondatabase/serverless": "^0.10.4",
    "@types/express-rate-limit": "^5.1.3",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^10.0.0",
    "csv-parser": "^3.2.0",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.18.1",
    "jsonwebtoken": "^9.0.2",
    "memorystore": "^1.6.7",
    "multer": "^2.0.2",
    "nodemailer": "8.0.5",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.13.1",
    "postgres": "^3.4.9",
    "stripe": "^18.0.0",
    "uuid": "^13.0.1",
    "vitest": "^4.0.13",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@replit/vite-plugin-cartographer": "^0.0.11",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.16.11",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "glob": "^13.0.6",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "rimraf": "^6.1.3",
    "superagent": "^10.3.0",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.5",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "npm@10.8.1",
  "turbo": {
    "enabled": true
  }
}
