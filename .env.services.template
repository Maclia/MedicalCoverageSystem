# ==========================================
# MICROSERVICES ENVIRONMENT CONFIGURATION
# ==========================================
# Copy to .env and update with your values

# --- Global Configuration ---
NODE_ENV=development
LOG_LEVEL=info

# --- API Gateway Configuration ---
GATEWAY_PORT=3001
API_GATEWAY_URL=http://api-gateway:3001

# --- Frontend Environment (required VITE_ prefix for Vite to expose to browser) ---
VITE_API_GATEWAY_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_CORE_SERVICE_URL=http://localhost:3003
VITE_BILLING_SERVICE_URL=http://localhost:3002
VITE_CRM_SERVICE_URL=http://localhost:3005
VITE_INSURANCE_SERVICE_URL=http://localhost:3008
VITE_HOSPITAL_SERVICE_URL=http://localhost:3007
VITE_FINANCE_SERVICE_URL=http://localhost:3004
VITE_MEMBERSHIP_SERVICE_URL=http://localhost:3006
VITE_WELLNESS_SERVICE_URL=http://localhost:3009
VITE_ANALYTICS_SERVICE_URL=http://localhost:3010
VITE_FRAUD_DETECTION_SERVICE_URL=http://localhost:3011
VITE_PREMIUM_CALCULATION_SERVICE_URL=http://localhost:3012

# --- Core Service ---
CORE_SERVICE_PORT=3003
CORE_SERVICE_URL=http://core-service:3003
CORE_DB_URL=postgresql://postgres:postgres@localhost:5432/medical_coverage_core
CORE_DB_POOL_SIZE=20

# --- Billing Service ---
BILLING_SERVICE_PORT=3002
BILLING_SERVICE_URL=http://billing-service:3002
BILLING_DB_URL=postgresql://postgres:postgres@localhost:5432/medical_coverage_billing
