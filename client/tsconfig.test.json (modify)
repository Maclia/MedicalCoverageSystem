{
	"compilerOptions": {
		"target": "es6",
		"module": "commonjs",
		"types": [
			"jest"
		],
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"src/**/*.test.ts"
	],
	"exclude": [
		"node_modules"
	]
}