{
  "name": "medical-coverage-analytics-service",
  "version": "1.0.0",
  "description": "Analytics service for Medical Coverage System - Real-time metrics and reporting",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "npx tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "db:push": "drizzle-kit push --config config/drizzle.analytics.config.ts",
    "db:studio": "drizzle-kit studio --config config/drizzle.analytics.config.ts"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.0",
    "axios": "^1.13.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "helmet": "^7.1.0",
    "pg": "^8.13.1",
    "pino": "^8.16.2",
    "uuid": "^13.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.16.11",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
