{
  "name": "medical-coverage-analytics-service",
  "version": "1.0.0",
  "description": "Analytics service for Medical Coverage System - Real-time metrics and reporting",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "db:push": "drizzle-kit push --config config/drizzle.analytics.config.ts",
    "db:studio": "drizzle-kit studio --config config/drizzle.analytics.config.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "drizzle-orm": "^0.28.1",
    "pg": "^8.11.1",
    "dotenv": "^16.3.1",
    "zod": "^3.22.2",
    "@types/express": "^4.17.17",
    "axios": "^1.6.0",
    "uuid": "^9.0.0",
    "date-fns": "^2.30.0",
    "pino": "^8.16.2"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "tsx": "^3.14.0",
    "@types/node": "^20.5.1",
    "@types/jest": "^29.5.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "drizzle-kit": "^0.19.3",
    "eslint": "^8.48.0"
  }
}
