{
  "name": "@medical-coverage/wellness-service",
  "version": "1.0.0",
  "description": "Wellness and health tracking microservice for Medical Coverage System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc || exit 0",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "docker:build": "docker build -t medical-coverage/wellness-service .",
    "docker:run": "docker run -p 3008:3008 medical-coverage/wellness-service"
  },
  "keywords": [
    "wellness",
    "health",
    "fitness",
    "tracking",
    "microservice",
    "typescript"
  ],
  "author": "Medical Coverage System",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.4.1",
    "@opentelemetry/auto-instrumentations-node": "^0.39.4",
    "@opentelemetry/sdk-node": "^0.41.2",
    "axios": "^1.4.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.11.3",
    "chart.js": "^4.3.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^6.8.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mpesa-api": "3.0.2",
    "node-cron": "^3.0.2",
    "nodemailer": "^8.0.5",
    "oauth": "^0.10.0",
    "passport": "^0.7.0",
    "passport-apple": "^2.0.2",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.13.1",
    "postgres": "^3.4.3",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "vite": "8.0.8",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.16.11",
    "@types/node-cron": "^3.0.8",
    "@types/nodemailer": "^6.4.9",
    "@types/oauth": "^0.9.1",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.11",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "dotenv": "^16.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
