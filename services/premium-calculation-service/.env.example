# ==================================================
# ✅ PREMIUM CALCULATION SERVICE ENVIRONMENT
# ==================================================
# STANDARD SERVICE CONFIGURATION - ALL SERVICES FOLLOW THIS FORMAT

# Server Configuration
PORT=3012
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration
PREMIUM_CALCULATION_DB_URL=postgresql://postgres:postgres@localhost:5432/medical_coverage
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medical_coverage

# Redis Configuration
REDIS_URL=redis://localhost:6379

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Service URLs for inter-service communication
SERVICES_CORE=http://localhost:3001
SERVICES_INSURANCE=http://localhost:3003
SERVICES_MEMBERSHIP=http://localhost:3004

# API Configuration
API_PREFIX=/api
REQUEST_TIMEOUT=30000
MAX_REQUEST_SIZE=1mb

# Security
JWT_SECRET=your-jwt-secret-key-here
API_KEY=premium-calculation-service-api-key

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# Feature Flags
ENABLE_BATCH_CALCULATION=true
ENABLE_CACHING=true
ENABLE_AUDIT_LOGGING=true