# Server Configuration
PORT=5009
NODE_ENV=development
LOG_LEVEL=info
LOG_FORMAT=json

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/medical_coverage_fraud_detection

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=your-secret-key-change-in-production

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# External Database Integrations
MIB_INTEGRATION=false
MIB_API_KEY=
MIB_API_URL=https://api.mib.com

NICB_INTEGRATION=false
NICB_API_KEY=
NICB_API_URL=https://api.nicb.org

NDH_INTEGRATION=false
NDH_API_KEY=
NDH_API_URL=https://api.ndh.org

# Geolocation
GEOLOCATION_API_KEY=
GEOLOCATION_API_URL=https://api.geolocation.com

# NLP Service
NLP_API_KEY=
NLP_API_URL=https://api.nlp.com

# API Gateway
API_GATEWAY_URL=http://api-gateway:5000

# Fraud Detection Configuration
FRAUD_DETECTION_SENSITIVITY=medium
FRAUD_ALERT_THRESHOLD=30
FRAUD_INVESTIGATION_THRESHOLD=50
FRAUD_AUTO_REVIEW_THRESHOLD=70

# Detection Methods
ENABLE_ML_DETECTION=false
ENABLE_NETWORK_ANALYSIS=false

# Rules Configuration
FREQUENCY_THRESHOLD=5
AMOUNT_MULTIPLIER=2.5

# Real-time Detection
REALTIME_DETECTION=false

# Investigation
AUTO_ASSIGN_INVESTIGATION=false
ESCALATION_ENABLED=false

# Automated Actions
AUTO_DENIAL_ENABLED=false
AUTO_RECOVERY_ENABLED=false
AUTO_RECOVERY_AMOUNT=1.2

# Pattern Learning
PATTERN_LEARNING=false
PATTERN_MIN_OCCURRENCES=5
PATTERN_CONFIDENCE=0.75
PATTERN_LEARNING_WINDOW=90
