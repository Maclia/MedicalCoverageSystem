{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "typeRoots": ["../node_modules/@types", "./node_modules/@types"],
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@medical-system/shared-business-rules": ["../shared/business-rules/src/index.ts"],
      "@medical-system/shared-business-rules/*": ["../shared/business-rules/src/*"]
    }
  },
  "references": [
    { "path": "../shared/business-rules" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/tests/**/*"]
}
