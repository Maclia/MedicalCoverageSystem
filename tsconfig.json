{
    "include": ["client/src/**/*", "shared/**/*", "server/**/*", "services/**/*", "config/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "build", "dist"],
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["es2015", "es2016", "es2017", "es2018", "es2019", "es2020", "esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types", "./server/types"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  }
}
