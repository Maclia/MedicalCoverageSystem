{
    "include": ["client/src/**/*", "server/**/*", "services/**/*", "config/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "build", "dist"],
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["es2015", "es2016", "es2017", "es2018", "es2019", "es2020", "esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "typeRoots": ["./node_modules/@types", "./server/types"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@root/*": ["./*"],
      "@shared/*": ["./services/shared/*"],
      "@app/*": ["./client/src/app/*"],
      "@features/*": ["./client/src/features/*"],
      "@services/*": ["./client/src/services/*"],
      "@assets/*": ["./client/src/assets/*"],
      "@pages/*": ["./client/src/pages/*"],
      "@lib/*": ["./client/src/lib/*"],
      "@components/*": ["./client/src/components/*"],
      "@ui/*": ["./client/src/ui/*"],
      "@hooks/*": ["./client/src/hooks/*"],
      "@utils/*": ["./client/src/utils/*"],
      "@types/*": ["./client/src/types/*"],
      "@config/*": ["./client/src/config/*"],
      "@contexts/*": ["./client/src/contexts/*"],
      "@guards/*": ["./client/src/guards/*"],
      "@system/*": ["./services/shared/*"]
    }
  }
}
